# Example environment configuration for RAG API
# Copy this file to .env and update the values as needed

# Docker Registry (for remote deployments)
DOCKER_REMOTE_REGISTRY=your-registry-name

# Database Configuration
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
DB_HOST=db
DB_PORT=5432

# Vector Database Type (pgvector or atlas-mongo)
VECTOR_DB_TYPE=pgvector

# Collection/Table Name
COLLECTION_NAME=testcollection

# Application Configuration
RAG_HOST=0.0.0.0
RAG_PORT=8000
DEBUG_RAG_API=true

# Document Processing
CHUNK_SIZE=1500
CHUNK_OVERLAP=100
PDF_EXTRACT_IMAGES=false

# Embeddings Configuration
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# REQUIRED: Add your OpenAI API key here
RAG_OPENAI_API_KEY=your-openai-api-key-here

# Optional: OpenAI Configuration
# RAG_OPENAI_BASEURL=https://api.openai.com/v1
# RAG_OPENAI_PROXY=

# Upload Directory
RAG_UPLOAD_DIR=./uploads/

# Logging
CONSOLE_JSON=false

# Optional: JWT Authentication
# JWT_SECRET=your-jwt-secret-here

# Optional: Azure OpenAI (if using Azure embeddings)
# RAG_AZURE_OPENAI_API_KEY=your-azure-api-key
# RAG_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# RAG_AZURE_OPENAI_API_VERSION=2023-05-15

# Optional: MongoDB Atlas (if using atlas-mongo)
# ATLAS_MONGO_DB_URI=mongodb+srv://username:password@cluster.mongodb.net/database
# ATLAS_SEARCH_INDEX=vector_index

# Optional: Other embedding providers
# HF_TOKEN=your-huggingface-token
# OLLAMA_BASE_URL=http://ollama:11434
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_DEFAULT_REGION=us-east-1
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json